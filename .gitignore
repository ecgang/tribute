# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright + screenshots
.playwright-mcp/
*.png
# ...but README/repo images under assets/ are intentional
!assets/*.png

# tsx cache
tsx-501/

# private workflow config (kept local, not published)
CLAUDE.md

# benchmark/kill-test local artifacts (results are generated, cache is transient)
scripts/.bench-cache/
scripts/benchmark-result-*
scripts/kill-test-result-*

# Internal planning docs — keep out of the public repo (live in ../tribute-private/)
/plans/
