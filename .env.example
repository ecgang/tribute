# Cost kill switch. Live generation + open-prompt are OFF unless this is exactly "1".
# Leave this UNSET on any PUBLIC deployment so anonymous traffic can't burn your keys.
LIVE_ENABLED=

# Live mode (optional). Without these, the demo runs in pre-computed mode.
ANTHROPIC_API_KEY=
# Optional model override for live generation + leave-one-out ablation.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Open-prompt mode (optional). Enables the "ask your own question" box:
# search → fetch real sources → generate → measure causal contribution.
# Needs ANTHROPIC_API_KEY too. Get a free key at https://tavily.com
TAVILY_API_KEY=
